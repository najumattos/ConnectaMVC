@model IEnumerable<ConnectaMVC.Models.ConsultaModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DataHoraConsulta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DuracaoConsulta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnotacoesConsulta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Psicologo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prontuario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataCadastro)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DataHoraConsulta)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DuracaoConsulta)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AnotacoesConsulta)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Psicologo.PsicologoId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prontuario.ProntuarioId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataCadastro)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ConsultaId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ConsultaId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ConsultaId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
