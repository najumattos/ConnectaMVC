@model IEnumerable<ConnectaMVC.Models.ProntuarioModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PsicologoResponsavel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Paciente)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataCriacao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataUltimaAtualizacao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Queixas)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipoProntuario)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.PsicologoResponsavel.PsicologoId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Paciente.PacienteId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataCriacao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataUltimaAtualizacao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Queixas)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipoProntuario)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProntuarioId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ProntuarioId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ProntuarioId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
