@{
    Layout = null; // Isso remove o header, footer e CSS padrão do sistema
    ViewData["Title"] = "Login - ConnectaMVC";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
            width: 350px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        h2 { text-align: center; margin-bottom: 30px; color: #4ecca3; }

        .form-group { margin-bottom: 20px; }

        label { display: block; margin-bottom: 5px; font-size: 0.9em; }

        input, select {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: none;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            box-sizing: border-box; /* Garante que o padding não estoure a largura */
        }

        input:focus, select:focus {
            outline: 2px solid #4ecca3;
            background: rgba(255, 255, 255, 0.2);
        }

        option { background: #1a1a2e; color: white; }

        .btn-login {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: #4ecca3;
            color: #1a1a2e;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-login:hover { background: #45b291; transform: translateY(-2px); }

        .btn-register {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #4ecca3;
            text-decoration: none;
            font-size: 0.85em;
        }

        .btn-register:hover { text-decoration: underline; }
    </style>
</head>
<body>

    <div class="login-card">
        <h2>Connecta Mente</h2>

        <form method="post" action="/Account/Login">
            <div class="form-group">
                <label>E-mail</label>
                <input type="email" name="Email" placeholder="seu@email.com" required />
            </div>

            <div class="form-group">
                <label>Senha</label>
                <input type="password" name="Password" placeholder="******" required />
            </div>

            <div class="form-group">
                <label>Tipo de Acesso</label>
                <select name="TipoPerfil">
                    <option value="1">Coordenador</option>
                    <option value="2">Estudante</option>
                </select>
            </div>

            <button type="submit" class="btn-login">ENTRAR</button>
        </form>

        <a href="/Account/Register" class="btn-register">Não tem uma conta? Cadastre-se</a>
    </div>

</body>
</html>